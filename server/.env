# MongoDB Configuration for Local Database
# For local MongoDB without authentication:
MONGO_URI=mongodb://localhost:27017/

# For local MongoDB with authentication (uncomment and fill if needed):
# MONGO_URI=mongodb://username:password@localhost:27017/photoshop?authSource=admin

# Database and Collection Names
MONGO_DB_NAME=Photoshop
MONGO_COLLECTION_NAME=logs

# Legacy support (will be removed - use MONGO_URI instead)
# DB_PASSKEY=your_mongodb_atlas_password
